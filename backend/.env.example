# 应用配置
APP_NAME=ASR智能质检系统
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置
DATABASE_URL=postgresql+asyncpg://asr_admin:asr_secure_2024@localhost:5432/asr_quality_db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ASR服务配置（可选，配置后将使用真实ASR服务）
ASR_API_URL=
ASR_API_KEY=

# LLM服务配置（可选，配置后将使用真实LLM服务）
LLM_API_URL=
LLM_API_KEY=

# 对象存储配置
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=asr-recordings
OSS_PUBLIC_BUCKET=asr-public

# 音频配置
AUDIO_MAX_SIZE=524288000
CHUNK_SIZE=5242880

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 预签名URL过期时间(秒)
PRESIGNED_URL_EXPIRE=300

# 审计日志配置
AUDIT_LOG_ENABLED=true
